# Template for the local secrets used by `make publish-nuget` / `make publish-github`.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
#   cp .env.example .env
#
# Values must be unquoted. An exported shell variable of the same name takes
# precedence over the value here.

NUGET_API_KEY=
GITHUB_TOKEN=
